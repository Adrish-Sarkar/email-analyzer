# ============================================================
# Email Analyzer — Root .gitignore
# Covers: frontend (Next.js) & backend (Node / Express / TS)
# ============================================================

# ---------------------------
# Dependencies
# ---------------------------
node_modules/
jspm_packages/
web_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---------------------------
# Environment files
# Keep .env.example committed so collaborators know what's needed
# ---------------------------
.env
.env.*
!.env.example
*.env
*.env.*

# ---------------------------
# Build & compiled output
# ---------------------------
dist/
build/
out/
.next/
*.js.map
*.tsbuildinfo

# ---------------------------
# Testing & coverage
# ---------------------------
coverage/

# ---------------------------
# Logs
# ---------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------------------------
# Next.js specific
# ---------------------------
next-env.d.ts
.vercel

# ---------------------------
# Docker
# ---------------------------
*.override.yml

# ---------------------------
# IDEs & editors
# ---------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---------------------------
# ---------------------------
# AI agent instruction files
# ---------------------------
CLAUDE.md
AGENTS.md

# ---------------------------
# OS artifacts
# ---------------------------
.DS_Store
Thumbs.db
*.pem
